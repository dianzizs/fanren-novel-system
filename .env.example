# MiniMax API 配置（仅用于 chat）
MINIMAX_API_KEY=your-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_CHAT_MODEL=MiniMax-m2.7-HighSpeed

# 本地 Embedding 配置
EMBEDDING_PROVIDER=local_openvino
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DEVICE=GPU
LOCAL_EMBEDDING_FALLBACK_DEVICE=CPU
LOCAL_EMBEDDING_BATCH_SIZE=32
LOCAL_EMBEDDING_NORMALIZE=true
LOCAL_EMBEDDING_CACHE_DIR=data/runtime/models

# 默认书籍配置（可修改）
DEFAULT_BOOK_ID=default-book
DEFAULT_BOOK_TITLE=默认小说
DEFAULT_BOOK_PATH=default-book.txt

# Tracing 配置
TRACE_ENABLED=true
TRACE_LOG_LEVEL=INFO
